	<queryString language="SQL">
		<![CDATA[SELECT 
  P.nombre + ' ' + P.app + ' ' + ISNULL(P.apm, '') AS nombrePaciente,
  Ci.fecha,
  Ci.motivo,
  Ci.consultorio,
  Ci.Estado
FROM Citas Ci
JOIN Pacientes P ON Ci.idPaciente = P.idPaciente
WHERE Ci.Estado = 'Pendiente'
ORDER BY Ci.fecha ASC]]>
	</queryString>
