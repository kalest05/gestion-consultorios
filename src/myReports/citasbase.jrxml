	<queryString language="SQL">
		<![CDATA[SELECT 
    c.idCita,
    p.nombre + ' ' + p.app + ' ' + p.apm AS nombrePaciente,
    m.nombre + ' ' + m.app + ' ' + m.apm AS nombreMedico,
    c.fecha,
    c.motivo,
    s.nombre AS nombreServicio,
    c.consultorio,
    c.comentarioA
FROM 
    Citas c
JOIN 
    Pacientes p ON c.idPaciente = p.idPaciente
JOIN 
    Medicos m ON c.idMedico = m.idMedico
JOIN 
    Servicios s ON c.idServicio = s.idServicio
ORDER BY 
    c.idCita]]>
	</queryString>
