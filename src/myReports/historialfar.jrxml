	<parameter name="idPac" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
  P.nombre + ' ' + P.app AS paciente,
  R.fecha,
  R.diagnostico,
  Med.nombre AS medicamento,
  RM.cantidad,
  R.instruccion
FROM Recetas R
JOIN Consultas C ON R.idConsulta = C.idConsulta
JOIN Citas Ci ON C.idCita = Ci.idCita
JOIN Pacientes P ON Ci.idPaciente = P.idPaciente
JOIN RECETAMEDICAMENTOS RM ON R.idReceta = RM.idReceta
JOIN Medicamentos Med ON RM.idMedicamento = Med.idMedicamento
WHERE P.idPaciente =  $P{idPac} 
ORDER BY R.fecha DESC]]>
	</queryString>
