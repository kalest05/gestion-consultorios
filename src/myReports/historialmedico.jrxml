	<parameter name="idPac" class="java.lang.Integer" nestedType="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
  P.idPaciente,
  P.nombre + ' ' + P.app + ' ' + ISNULL(P.apm, '') AS Paciente,
  P.edad,
  P.genero,
  Ci.fecha AS fechaCita,
  Ci.motivo,
  Co.fecha AS fechaConsulta,
  Co.diagnostico,
  Co.observaciones,
  Co.presion,
  Co.temp,
  Co.altura,
  Co.peso
FROM Pacientes P
JOIN Citas Ci ON P.idPaciente = Ci.idPaciente
JOIN Consultas Co ON Co.idCita = Ci.idCita
WHERE P.idPaciente =  $P{idPac} 
ORDER BY Co.fecha DESC]]>
	</queryString>
