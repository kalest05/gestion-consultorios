	<parameter name="Nombre" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
  Med.nombre,
  I.lote,
  I.CantidadDisp,
  I.Estado,
  I.FechaIngreso,
  Med.fecVenc
FROM Inventario I
JOIN Medicamentos Med ON I.idMedicamento = Med.idMedicamento
WHERE Med.nombre =  $P{Nombre} 
ORDER BY I.FechaIngreso DESC]]>
	</queryString>
