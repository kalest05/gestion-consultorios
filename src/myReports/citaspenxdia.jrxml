	<parameter name="Fecha" class="java.util.Date"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
  Ci.fecha,
  P.nombre + ' ' + P.app + ' ' + ISNULL(P.apm, '') AS nombrePaciente,
  M.nombre + ' ' + M.app AS nombreMedico,
  S.nombre AS servicio,
  Ci.motivo,
  Ci.consultorio,
  Ci.Estado
FROM Citas Ci
JOIN Pacientes P ON Ci.idPaciente = P.idPaciente
JOIN Medicos M ON Ci.idMedico = M.idMedico
JOIN Servicios S ON Ci.idServicio = S.idServicio
WHERE CAST(Ci.fecha AS DATE) = $P{Fecha} 
  AND Ci.Estado = 'Pendiente'
ORDER BY Ci.fecha ASC]]>
	</queryString>
