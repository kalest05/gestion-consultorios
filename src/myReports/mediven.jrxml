	<parameter name="FechaLimite" class="java.util.Date">
		<parameterDescription><![CDATA[Fecha a verificar el vencimiento]]></parameterDescription>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT 
  m.idMedicamento, 
  m.nombre AS nombreMedicamento, 
  m.codigoB, 
  m.marca, 
  m.laboratorio, 
  m.formula, 
  m.fecVenc, 
  m.mgUnidad, 
  m.claveR, 
  p.nombre AS nombrePresentacion
FROM 
  Medicamentos m
INNER JOIN 
  PresentacionMed p ON m.idPresentacion = p.idPresentacion
WHERE 
  m.fecVenc < $P{FechaLimite}]]>
	</queryString>
