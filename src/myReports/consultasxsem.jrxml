	<queryString language="SQL">
		<![CDATA[SELECT c.idConsulta, ct.idCita, c.fecha, c.diagnostico, c.observaciones, c.presion, c.temp, c.altura, c.peso 
		          FROM Consultas c
		          LEFT JOIN Citas ct ON ct.idCita = c.idCita 
				  WHERE c.fecha <= DATEADD(DAY, 7, GETDATE())]]>
	</queryString>
