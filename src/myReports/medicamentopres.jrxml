	<queryString language="SQL">
		<![CDATA[SELECT 
  PM.nombre AS tipoPresentacion,
  Med.nombre AS medicamento,
  I.CantidadDisp
FROM Medicamentos Med
JOIN PresentacionMed PM ON Med.idPresentacion = PM.idPresentacion
JOIN Inventario I ON Med.idMedicamento = I.idMedicamento
ORDER BY tipoPresentacion, Med.nombre]]>
	</queryString>
