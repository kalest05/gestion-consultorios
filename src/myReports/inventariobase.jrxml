	<queryString language="SQL">
		<![CDATA[SELECT i.idInventario, m.nombre AS Medicamento, i.CantidadDisp, i.FechaIngreso, i.Estado, i.lote
	FROM Inventario i 
	INNER JOIN Medicamentos m ON i.idMedicamento = m.idMedicamento]]>
	</queryString>
