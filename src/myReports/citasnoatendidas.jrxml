	<queryString language="SQL">
		<![CDATA[SELECT 
  Ci.fecha,
  P.nombre + ' ' + P.app AS paciente,
  M.nombre + ' ' + M.app AS medico,
  Ci.Estado
FROM Citas Ci
LEFT JOIN Consultas C ON Ci.idCita = C.idCita
JOIN Pacientes P ON Ci.idPaciente = P.idPaciente
JOIN Medicos M ON Ci.idMedico = M.idMedico
WHERE C.idConsulta IS NULL AND Ci.fecha <= DATEADD(DAY, 7, GETDATE())
ORDER BY Ci.fecha DESC]]>
	</queryString>
