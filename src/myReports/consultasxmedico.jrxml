	<parameter name="Medico" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
  M.nombre + ' ' + M.app + ' ' + ISNULL(M.apm, '') AS nombreMedico,
  C.fecha AS fechaConsulta,
  P.nombre + ' ' + P.app + ' ' + ISNULL(P.apm, '') AS nombrePaciente,
  C.diagnostico,
  C.observaciones
FROM Consultas C
JOIN Citas Ci ON C.idCita = Ci.idCita
JOIN Medicos M ON Ci.idMedico = M.idMedico
JOIN Pacientes P ON Ci.idPaciente = P.idPaciente
WHERE M.idMedico =  $P{Medico} 
ORDER BY C.fecha DESC]]>
	</queryString>
	<field name="nombreMedico" class="java.lang.String">
