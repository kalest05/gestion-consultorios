	<parameter name="Fecha" class="java.util.Date"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
  M.nombre + ' ' + M.app AS nombreMedico,
  Ci.Estado,
  COUNT(*) AS totalCitas
FROM Citas Ci
JOIN Medicos M ON Ci.idMedico = M.idMedico
WHERE CAST(Ci.fecha AS DATE) = $P{Fecha} 
GROUP BY M.nombre, M.app, Ci.Estado

ORDER BY nombreMedico, Estado]]>
	</queryString>
	<field name="nombreMedico" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nombreMedico"/>
