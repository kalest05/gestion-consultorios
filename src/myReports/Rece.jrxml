	<parameter name="idRece" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
          pac.nombre + ' ' + pac.app + ' ' + pac.apm AS Paciente, 
          med.nombre + ' ' + med.app + ' ' + med.apm AS Medico, 
          c.fecha, 
          c.diagnostico, 
          c.instruccion, 
          rm.cantidad, 
          m.nombre AS Medicamento,
          co.presion,
          co.temp,
          co.altura,
          co.peso
        FROM Recetas c
        INNER JOIN RecetaMedicamentos rm ON rm.idReceta = c.idReceta
        INNER JOIN Medicamentos m ON rm.idMedicamento = m.idMedicamento
        INNER JOIN Consultas co ON c.idConsulta = co.idConsulta
        INNER JOIN Citas ci ON co.idCita = ci.idCita
        INNER JOIN Medicos med ON ci.idMedico = med.idMedico
        INNER JOIN Pacientes pac ON ci.idPaciente = pac.idPaciente
        WHERE c.idReceta= $P{idRece}]]>
	</queryString>
	<field name="Paciente" class="java.lang.String"/>
	<field name="Medico" class="java.lang.String"/>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="diagnostico" class="java.lang.String"/>
	<field name="instruccion" class="java.lang.String"/>
	<field name="cantidad" class="java.lang.Integer"/>
	<field name="Medicamento" class="java.lang.String"/>
	<field name="presion" class="java.lang.String"/>
	<field name="temp" class="java.lang.String"/>
	<field name="altura" class="java.lang.String"/>
	<field name="peso" class="java.lang.String"/>
