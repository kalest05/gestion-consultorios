	<parameter name="Nombre" class="java.lang.String">
		<parameterDescription><![CDATA[Busqueda por nombre]]></parameterDescription>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT 
    p.idPaciente, 
    p.nombre, 
    p.app, 
    p.apm, 
    p.fecNac, 
    p.edad, 
    p.curp, 
    p.genero, 
    p.alergias, 
    p.tipoSangre, 
    p.municipio, 
    p.localidad, 
    p.numCasa, 
    p.nomCalle, 
    r.nombre AS Religion, 
    p.telefono
FROM Pacientes p
INNER JOIN Religiones r ON p.idReligion = r.idReligion
WHERE p.nombre LIKE CONCAT( '%',  $P{Nombre}, '%')]]>
	</queryString>
