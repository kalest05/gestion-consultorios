	<queryString language="SQL">
		<![CDATA[SELECT 
  Med.nombre,
  Med.marca,
  I.Estado,
  I.lote
FROM Inventario I
JOIN Medicamentos Med ON I.idMedicamento = Med.idMedicamento
WHERE I.Estado = 'Agotado']]>
	</queryString>
