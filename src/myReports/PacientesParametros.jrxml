	<parameter name="FechaLimite" class="java.sql.Date">
		<parameterDescription><![CDATA[Fecha Limite a reportar]]></parameterDescription>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT 
    p.idPaciente, 
    p.nombre, 
    p.app, 
    p.apm, 
    p.fecNac, 
    p.edad, 
    p.curp, 
    p.genero, 
    p.alergias, 
    p.tipoSangre, 
    p.municipio, 
    p.localidad, 
    p.numCasa, 
    p.nomCalle, 
    r.nombre AS Religion, 
    p.telefono
FROM Pacientes p
INNER JOIN Religiones r ON p.idReligion = r.idReligion
WHERE NOT EXISTS (
    SELECT 1 
    FROM Citas c 
    WHERE c.idPaciente = p.idPaciente
      AND c.fecha >=  $P{FechaLimite} )]]>
	</queryString>
