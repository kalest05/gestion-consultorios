	<queryString language="SQL">
		<![CDATA[SELECT 
  S.nombre AS servicio,
  COUNT(DISTINCT R.idReceta) AS totalRecetas,
  SUM(RM.cantidad) AS totalMedicamentos
FROM Recetas R
JOIN Consultas C ON R.idConsulta = C.idConsulta
JOIN Citas Ci ON C.idCita = Ci.idCita
JOIN Servicios S ON Ci.idServicio = S.idServicio
JOIN RECETAMEDICAMENTOS RM ON RM.idReceta = R.idReceta
GROUP BY S.nombre
ORDER BY totalRecetas DESC]]>
	</queryString>
